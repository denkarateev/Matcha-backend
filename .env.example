# ============================================================
# MATCHA Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- Database (PostgreSQL via asyncpg) ---
DATABASE_URL=postgresql+asyncpg://matcha:matcha_dev@localhost:5432/matcha

# --- Cache (Redis) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-minimum-32-characters

# --- Application ---
ENV=development
APP_NAME=MATCHA Backend

# --- Timezone (Bali WITA = UTC+8) ---
BUSINESS_TIMEZONE=Asia/Makassar

# --- Legacy keys (no longer required but harmless) ---
# MATCHA_SEED_DEMO_DATA=false
